<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
      "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
      
<mapper namespace="com.example.demo.company.dao.ICompanyMyPage">
	
	<select id="findCUser" resultType="com.example.demo.company.dto.CompanyUserDTO">
		select * FROM COMPANY_USERS where login_id=#{login_id}
	</select>
	
	<select id="findAcnt" resultType="com.example.demo.company.dto.AccountsCompanyDTO">
		select * FROM ACCOUNTS_COMPANY where com_no = #{com_no}
	</select>
	
	<select id="findFAcnt" resultType="com.example.demo.company.dto.ForeignAccountsCompanyDTO">
		select * FROM FOREIGN_ACCOUNTS_COMPANY where usr_no = #{usr_no}
	</select>
	<select id="findCompany" resultType="com.example.demo.company.dto.CompaniesDTO">
		select * from COMPANIES where com_no = #{com_no}
	</select>
</mapper>
