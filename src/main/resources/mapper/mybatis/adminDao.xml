<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.demo.admin.dao.IAdminDao">

    <!-- 관리자 회원가입 -->
    <insert id="join"
            parameterType="com.example.demo.admin.dto.AdminDto">

        INSERT INTO ADMIN_USERS
        (
            adm_no,
            lgn_id,
            secu_pw,
            department,
            secu_adm_pwd,
            name,
            adm_role
        )
        VALUES
            (
                SEQ_ADMIN_USERS.NEXTVAL,
                #{login_id},
                #{password},
                #{department},
                #{admin_pw},
                #{name},
                #{admin_role}
            )

    </insert>

    <!-- 로그인 -->
    <resultMap id="adminMap"
               type="com.example.demo.admin.dto.AdminDto">

        <result property="admin_id" column="adm_no"/>
        <result property="login_id" column="lgn_id"/>
        <result property="password" column="secu_pw"/>
        <result property="department" column="department"/>
        <result property="admin_pw" column="secu_adm_pwd"/>
        <result property="name" column="name"/>
        <result property="admin_role" column="adm_role"/>

    </resultMap>
    <select id="login"
            parameterType="com.example.demo.admin.dto.AdminDto"
            resultMap="adminMap">

        SELECT *
        FROM ADMIN_USERS
        WHERE lgn_id = #{login_id}

    </select>


    <!-- 내 정보 조회 -->
    <select id="selectMyPage"
            parameterType="com.example.demo.admin.dto.AdminDto"
            resultType="com.example.demo.admin.dto.AdminDto">

        SELECT *
        FROM ADMIN_USERS
        WHERE adm_no = #{admin_id}

    </select>

    <!-- 내 정보 수정 -->
    <update id="updateMyPage"
            parameterType="com.example.demo.admin.dto.AdminDto">

        UPDATE ADMIN_USERS
        SET
            department = #{department},
            name = #{name},
            adm_role = #{admin_role}
        WHERE adm_no = #{admin_id}

    </update>

    <!-- 비밀번호 변경 -->
    <update id="updatePassword" parameterType="com.example.demo.admin.dto.AdminDto">
        UPDATE ADMIN_USERS SET secu_pw = #{password} where adm_no = #{admin_id}
    </update>

    <!-- 관리자 비밀번호 변경 -->
    <update id="updateAdminPw" parameterType="com.example.demo.admin.dto.AdminDto">
        UPDATE ADMIN_USERS SET secu_adm_pwd = #{admin_pw} where adm_no = #{admin_id}
    </update>


</mapper>
