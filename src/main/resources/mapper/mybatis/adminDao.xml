<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.demo.admin.dao.IAdminDao">

    <!-- 관리자 회원가입 -->
    <insert id="join"
            parameterType="com.example.demo.admin.dto.AdminDto">

        INSERT INTO ADMIN_USERS
        (
            admin_id,
            login_id,
            password,
            department,
            admin_pw,
            name,
            admin_role
        )
        VALUES
            (
                #{admin_id},
                #{login_id},
                #{password},
                #{department},
                #{admin_pw},
                #{name},
                #{admin_role}
            )

    </insert>

    <!-- 로그인 -->
    <select id="login"
            parameterType="com.example.demo.admin.dto.AdminDto"
            resultType="com.example.demo.admin.dto.AdminDto">

        SELECT
            admin_id,
            admin_pw
        FROM ADMIN_USERS
        WHERE admin_id = #{admin_id}

    </select>

    <!-- 내 정보 조회 -->
    <select id="selectMyPage"
            parameterType="com.example.demo.admin.dto.AdminDto"
            resultType="com.example.demo.admin.dto.AdminDto">

        SELECT *
        FROM ADMIN_USERS
        WHERE admin_id = #{admin_id}

    </select>

    <!-- 내 정보 수정 -->
    <update id="updateMyPage"
            parameterType="com.example.demo.admin.dto.AdminDto">

        UPDATE ADMIN_USERS
        SET
            login_id = #{login_id},
            password = #{password},
            department = #{department},
            admin_pw = #{admin_pw},
            name = #{name},
            admin_role = #{admin_role}
        WHERE admin_id = #{admin_id}

    </update>

</mapper>