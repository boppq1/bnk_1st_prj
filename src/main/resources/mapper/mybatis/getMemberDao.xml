	</select>
	
	<delete id="deleteCompanySuggestKeyword">
		delete from suggested_search where role_type = 'ROLE_COMPANY' and suggested_no = (select min(suggested_no) from suggested_search where role_type = 'ROLE_COMPANY')
	</delete>
	
	<delete id="deletePersonalSuggestKeyword">
		delete from suggested_search where role_type = 'ROLE_PERSONAL' and suggested_no = (select min(suggested_no) from suggested_search where role_type = 'ROLE_PERSONAL')
	</delete>
	
	<update id="truncateSuggestSearch">
		truncate table suggested_search
	</update>
	
	<insert id="updateSuggestKeyword">
    INSERT INTO suggested_search (SUGGESTED_NO, ROLE_TYPE, KEYWORD, SEARCH_VOLUME)
    SELECT 
        SEQ_SUGGESTED_SEARCH.NEXTVAL,  role_type,                 keyword,                   search_volume              FROM ( 
        SELECT 
            role_type, 
            keyword, 
            search_volume, 
            ROW_NUMBER() OVER (PARTITION BY role_type ORDER BY search_volume DESC) as rnum
        FROM search_log SL 
        WHERE role_type IN ('ROLE_COMPANY', 'ROLE_PERSONAL') 
          AND NOT EXISTS ( 
              SELECT 1  
              FROM keyword_ban KB 
              WHERE KB.keyword = SL.keyword
          )
    ) 
    WHERE rnum &lt;= 5
</insert>
