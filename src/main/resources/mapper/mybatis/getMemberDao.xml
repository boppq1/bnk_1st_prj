<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.admin.dao.IListDao">
	<select id="getAdmin" resultType="com.example.MybatisPrj.jdbc.MyUserDto">
		select * from admin_users
	</select>
	
	<select id="getAdmins" resultType="com.example.MybatisPrj.jdbc.MyUserDto">
		select * from admin_users where id = #{admin_id}
	</select>
	
	<select id="getUser" resultType="com.example.MybatisPrj.jdbc.MyUserDto">
		select * from myuser
	</select>
	
	<select id="getUsers" resultType="com.example.MybatisPrj.jdbc.MyUserDto">
		select * from myuser where id = #{user_id}
	</select>
</mapper>