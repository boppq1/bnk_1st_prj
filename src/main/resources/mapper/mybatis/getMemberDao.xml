<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.admin.dao.IListDao">
	<select id="getAdmin" resultType="com.example.demo.admin.dto.AdminDto">
		select * from admin_users where admin_id = #{admin_id}
	</select>
	
	<select id="getAdmins" resultType="com.example.demo.admin.dto.AdminDto">
		select * from admin_users
	</select>
	
	<select id="getUser" resultType="com.example.demo.personal.dto.UserDTO">
		select * from users where user_id = #{user_id}
	</select>
	
	<select id="getUsers" resultType="com.example.demo.personal.dto.UserDTO">
		select * from users
	</select>
	
	<select id="getCompanies" resultType="com.example.demo.admin.dto.CompaniesDto">
		select * from companies
	</select>
	
	<select id="getCompanyUser" resultType="com.example.demo.company.dto.CompanyUserDTO">
		select * from COMPANY_USERS where company_user_id = ${company_user_id}
	</select>
	
	<select id="getCompanyUsers" resultType="com.example.demo.company.dto.CompanyUserDTO">
		select * from COMPANY_USERS
	</select>
	
	<update id="updateAdmin">
		update admin_users set password = #{password}, department = #{department}, admin_pw = #{admin_pw}, name = #{name}, admin_role = #{admin_role}  where admin_id = #{admin_id}
	</update>
	
	<update id="updateUser">
		update users set password = #{password}, name = #{name}, phone = #{phone}, birth = #{birth}, email = #{email}, gender = #{gender}, e_name = #{e_name}, postal_code = #{postal_code}, address = #{address}, address_detail = #{address_detail} where user_id = #{user_id}
	</update>
	
	<update id="updateCompanyUser">
		update company_users set password = #{password}, name = #{name}, phone = #{phone}, birth = #{birth}, email = #{email}, status = #{status}, gender = #{gender}, e_name = #{e_name} where company_user_id = #{company_user_id}
	</update>
	
	<select id="getPersonalDomesticAccount" resultType="com.example.demo.personal.dto.Accounts_personalDTO">
		select * from ACCOUNTS_PERSONAL where user_id = #{user_id}
	</select>
	
	<select id="getPersonalForeignAccount" resultType="com.example.demo.personal.dto.Foreign_accounts_personal">
		select * from FOREIGN_ACCOUNTS_PERSONAL where user_id = #{user_id}
	</select>
	
	<select id="getCompanyDomesticAccount" resultType="com.example.demo.company.dto.AccountsCompanyDTO">
		select * from ACCOUNTS_COMPANY where company_id = #{company_id}
	</select>
	
	<select id="getCompanyForeignAccount" resultType="com.example.demo.company.dto.ForeignAccountsCompanyDTO">
		select * from FOREIGN_ACCOUNTS_COMPANY where company_id = #{company_id}
	</select>
	
	<select id="getSearchPersonalLog" resultType="com.example.demo.admin.dto.SearchLogDto">
		select * from search_log where role_type = 'ROLE_PERSONAL'
	</select>
	
	<select id="getSuggestPersonalSearch" resultType="com.example.demo.admin.dto.SuggestedSearchDto">
		select * from suggested_search where role_type = 'ROLE_PERSONAL'
	</select>
	
	<select id="getSearchCompanyLog" resultType="com.example.demo.admin.dto.SearchLogDto">
		select * from search_log where role_type = 'ROLE_COMPANY'
	</select>
	
	<select id="getSuggestCompanySearch" resultType="com.example.demo.admin.dto.SuggestedSearchDto">
		select * from suggested_search where role_type = 'ROLE_COMPANY'
	</select>
</mapper>