<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

 <mapper namespace="com.example.demo.admin.dao.IListDao">
	<select id="getApproval" resultType="com.example.demo.admin.dto.ApprovalDto">
		select * from product where product_id = #{product_id}
	</select>
	
	<select id="getApprovals" resultType="com.example.demo.admin.dto.ApprovalDto">
		select * from PRODUCT_APPROVAL_REQUEST where request_status not in 'APPROVED'
	</select>
	
	<update id="updateApproval">
		update PRODUCT_APPROVAL_REQUEST set #{param1} where product_id = #{param2}
	</update>
	
	<update id="updateProduct">
		update product set #{param1} where product_id = #{param2}
	</update>
</mapper>